#!/usr/bin/env Rscript

# ================================================================
# Figure 6: facility contributions to cumulative national
# population-weighted exposure, 1940–1990
#
# (a) Facility contribution concentration (Pareto curve)
# (b) Twenty facilities with the largest cumulative contributions
# (c) Exposure reduction under two facility-targeting strategies
# ================================================================

rm(list = ls(all.names = TRUE))
graphics.off()

suppressPackageStartupMessages({
  library(data.table)
  library(ggplot2)
  library(scales)
  library(grid)
  library(gridExtra)
})

# ------------------------------
# 0. Settings
# ------------------------------

FIG6_BASE_DIR <- paste0(
  "/scratch/xshan2/R_Code/disperseR/main/output/",
  "pm25_decades_model.lm.cv_single_poly_proxy1999met"
)

FIG6_DATA_DIR <- file.path(
  FIG6_BASE_DIR,
  "facility_concentration_analysis"
)

FIG6_OUT_DIR <- file.path(FIG6_BASE_DIR, "figures_revised")
dir.create(FIG6_OUT_DIR, recursive = TRUE, showWarnings = FALSE)

FIG6_FACILITY_FILE <- file.path(
  FIG6_DATA_DIR,
  "facility_cumulative_contribution_1940_1990.csv"
)

FIG6_SHARE_FILE <- file.path(
  FIG6_DATA_DIR,
  "FIG_4A_top_facility_exposure_shares.csv"
)

FIG6_TOP_FILE <- file.path(
  FIG6_DATA_DIR,
  "FIG_4B_top_facility_contributions.csv"
)

FIG6_TARGET_FILE <- file.path(
  FIG6_DATA_DIR,
  "FIG_4C_targeting_efficiency.csv"
)

FIG6_WIDTH <- 7.4
FIG6_HEIGHT <- 7.8
FIG6_DPI <- 600

required_files <- c(
  FIG6_FACILITY_FILE,
  FIG6_SHARE_FILE,
  FIG6_TOP_FILE,
  FIG6_TARGET_FILE
)

missing_files <- required_files[!file.exists(required_files)]
if (length(missing_files) > 0) {
  stop("Missing Figure 6 input files:\n", paste(missing_files, collapse = "\n"))
}

message("Figure 6 data directory: ", FIG6_DATA_DIR)
message("Figure 6 output directory: ", FIG6_OUT_DIR)

# ------------------------------
# 1. Shared publication theme
# ------------------------------

fig6_theme <- function(base_size = 10) {
  theme_classic(base_size = base_size, base_family = "sans") +
    theme(
      text = element_text(color = "black"),
      plot.title.position = "plot",
      plot.title = element_text(
        size = base_size + 1,
        face = "bold",
        hjust = 0,
        margin = margin(t = 0, b = 4)
      ),
      axis.title = element_text(size = base_size, color = "black"),
      axis.text = element_text(size = base_size - 1, color = "black"),
      axis.ticks = element_line(color = "black", linewidth = 0.35),
      axis.ticks.length = unit(0.14, "cm"),
      panel.border = element_rect(
        color = "black", fill = NA, linewidth = 0.45
      ),
      panel.grid.major = element_line(color = "grey88", linewidth = 0.3),
      panel.grid.minor = element_blank(),
      legend.title = element_blank(),
      legend.text = element_text(size = base_size - 1),
      plot.margin = margin(6, 7, 6, 7)
    )
}

# ------------------------------
# 2. Read and validate data
# ------------------------------

fig6_facility <- fread(FIG6_FACILITY_FILE)
fig6_shares <- fread(FIG6_SHARE_FILE)
fig6_top <- fread(FIG6_TOP_FILE)
fig6_target <- fread(FIG6_TARGET_FILE)

facility_required <- c(
  "Plant_ID", "cumulative_exposure_contrib", "cumulative_SO2_tons"
)
share_required <- c("cutoff", "exposure_percent", "total_facilities")
top_required <- c(
  "Plant_ID", "cumulative_exposure_contrib", "Plant_Name", "Plant_State", "label"
)
target_required <- c(
  "cutoff_percent", "strategy", "exposure_reduction_percent", "n_removed"
)

if (length(setdiff(facility_required, names(fig6_facility))) > 0) {
  stop("Facility cumulative-contribution file has missing columns.")
}
if (length(setdiff(share_required, names(fig6_shares))) > 0) {
  stop("Facility exposure-share file has missing columns.")
}
if (length(setdiff(top_required, names(fig6_top))) > 0) {
  stop("Top-facility file has missing columns.")
}
if (length(setdiff(target_required, names(fig6_target))) > 0) {
  stop("Targeting-efficiency file has missing columns.")
}

fig6_facility[, cumulative_exposure_contrib := as.numeric(cumulative_exposure_contrib)]
fig6_facility[, cumulative_SO2_tons := as.numeric(cumulative_SO2_tons)]
fig6_facility <- fig6_facility[
  is.finite(cumulative_exposure_contrib) &
    !is.na(cumulative_exposure_contrib) &
    cumulative_exposure_contrib >= 0
]

if (nrow(fig6_facility) == 0 || sum(fig6_facility$cumulative_exposure_contrib) <= 0) {
  stop("No positive cumulative facility exposure contributions were found.")
}

# ------------------------------
# 3. Panel (a): Pareto curve
# ------------------------------

setorder(fig6_facility, -cumulative_exposure_contrib)

fig6_facility[, facility_rank := seq_len(.N)]
fig6_facility[, facilities_ranked_percent := facility_rank / .N * 100]
fig6_facility[, cumulative_exposure_percent :=
  cumsum(cumulative_exposure_contrib) /
    sum(cumulative_exposure_contrib) * 100]

# Add the origin so the curve starts at (0, 0).
fig6_pareto <- rbind(
  data.table(
    facilities_ranked_percent = 0,
    cumulative_exposure_percent = 0
  ),
  fig6_facility[, .(
    facilities_ranked_percent,
    cumulative_exposure_percent
  )]
)

fig6_shares[, facilities_ranked_percent := as.numeric(cutoff) * 100]
fig6_shares[, exposure_percent := as.numeric(exposure_percent)]

fig6_panel_a <- ggplot(
  fig6_pareto,
  aes(
    x = facilities_ranked_percent,
    y = cumulative_exposure_percent
  )
) +
  geom_abline(
    intercept = 0,
    slope = 1,
    color = "grey40",
    linetype = "dashed",
    linewidth = 0.6
  ) +
  geom_line(color = "#0072B2", linewidth = 1.05) +
  geom_point(
    data = fig6_shares,
    aes(
      x = facilities_ranked_percent,
      y = exposure_percent
    ),
    inherit.aes = FALSE,
    shape = 21,
    size = 2.1,
    stroke = 0.65,
    color = "#0072B2",
    fill = "white"
  ) +
  scale_x_continuous(
    breaks = seq(0, 100, by = 25),
    limits = c(0, 100),
    expand = expansion(mult = c(0, 0.015))
  ) +
  scale_y_continuous(
    breaks = seq(0, 100, by = 25),
    limits = c(0, 100),
    expand = expansion(mult = c(0, 0.015))
  ) +
  labs(
    title = "(a)",
    x = "Facilities ranked by exposure contribution (%)",
    y = "Cumulative exposure contribution (%)"
  ) +
  fig6_theme(base_size = 9.5) +
  theme(plot.margin = margin(5, 8, 8, 7))

# ------------------------------
# 4. Panel (b): top 20 facilities
# ------------------------------

fig6_top[, cumulative_exposure_contrib := as.numeric(cumulative_exposure_contrib)]
fig6_top <- fig6_top[
  is.finite(cumulative_exposure_contrib) &
    !is.na(cumulative_exposure_contrib)
]
setorder(fig6_top, -cumulative_exposure_contrib)
fig6_top <- head(fig6_top, 20)

fig6_top[
  is.na(label) | trimws(label) == "",
  label := paste0("Plant ", Plant_ID)
]

fig6_top[, contribution_scaled := cumulative_exposure_contrib * 1e3]
fig6_top[, plot_label := factor(label, levels = rev(unique(label)))]

fig6_panel_b <- ggplot(
  fig6_top,
  aes(x = contribution_scaled, y = plot_label)
) +
  geom_col(width = 0.68, fill = "#3B6FB6") +
  scale_x_continuous(
    labels = label_number(accuracy = 1),
    expand = expansion(mult = c(0, 0.06))
  ) +
  labs(
    title = "(b)",
    x = expression(
      atop(
        "Cumulative contribution to national PWE",
        "(" * 10^{-3} * " " * mu * "g " * m^{-3} * ")"
      )
    ),
    y = NULL
  ) +
  fig6_theme(base_size = 9.2) +
  theme(
    axis.text.y = element_text(size = 7.6),
    axis.title.x = element_text(size = 8.8, margin = margin(t = 7)),
    plot.margin = margin(5, 12, 15, 8)
  )

# ------------------------------
# 5. Panel (c): targeting efficiency
# ------------------------------

fig6_target[, cutoff_percent := as.numeric(cutoff_percent)]
fig6_target[, exposure_reduction_percent := as.numeric(exposure_reduction_percent)]
fig6_target <- fig6_target[
  is.finite(cutoff_percent) & is.finite(exposure_reduction_percent)
]

strategy_levels <- c(
  "Exposure-based ranking",
  "SO2 emissions-based ranking"
)
fig6_target[, strategy := factor(strategy, levels = strategy_levels)]

strategy_colors <- c(
  "Exposure-based ranking" = "#0072B2",
  "SO2 emissions-based ranking" = "#D55E00"
)
strategy_linetypes <- c(
  "Exposure-based ranking" = "solid",
  "SO2 emissions-based ranking" = "dashed"
)
strategy_shapes <- c(
  "Exposure-based ranking" = 16,
  "SO2 emissions-based ranking" = 17
)

fig6_panel_c <- ggplot(
  fig6_target,
  aes(
    x = cutoff_percent,
    y = exposure_reduction_percent,
    color = strategy,
    linetype = strategy,
    shape = strategy,
    group = strategy
  )
) +
  geom_line(linewidth = 0.9) +
  geom_point(size = 2.1) +
  scale_color_manual(values = strategy_colors, breaks = strategy_levels) +
  scale_linetype_manual(values = strategy_linetypes, breaks = strategy_levels) +
  scale_shape_manual(values = strategy_shapes, breaks = strategy_levels) +
  scale_x_continuous(
    breaks = c(0, 5, 10, 20, 30),
    limits = c(0, 30),
    expand = expansion(mult = c(0.01, 0.02))
  ) +
  scale_y_continuous(
    breaks = seq(0, 80, by = 20),
    limits = c(0, 80),
    expand = expansion(mult = c(0, 0.02))
  ) +
  labs(
    title = "(c)",
    x = "Facilities targeted (%)",
    y = "Cumulative exposure reduced (%)"
  ) +
  guides(
    color = guide_legend(nrow = 2, byrow = TRUE),
    linetype = guide_legend(nrow = 2, byrow = TRUE),
    shape = guide_legend(nrow = 2, byrow = TRUE)
  ) +
  fig6_theme(base_size = 9.5) +
  theme(
    legend.position = "bottom",
    legend.direction = "vertical",
    legend.key.width = unit(1.2, "cm"),
    legend.margin = margin(2, 0, 0, 0),
    plot.margin = margin(7, 8, 12, 7)
  )

# ------------------------------
# 6. Combine panels
# ------------------------------

fig6_layout <- rbind(
  c(1, 2),
  c(3, 2)
)

fig6_combined_grob <- gridExtra::arrangeGrob(
  fig6_panel_a,
  fig6_panel_b,
  fig6_panel_c,
  layout_matrix = fig6_layout,
  widths = c(0.84, 1.16),
  heights = c(1, 1),
  padding = unit(0.12, "cm")
)

grid::grid.newpage()
grid::grid.draw(fig6_combined_grob)

# ------------------------------
# 7. Save PDF, PNG, and TIFF
# ------------------------------

fig6_pdf_file <- file.path(FIG6_OUT_DIR, "Figure_6_facility_contributions.pdf")
fig6_png_file <- file.path(FIG6_OUT_DIR, "Figure_6_facility_contributions.png")
fig6_tiff_file <- file.path(FIG6_OUT_DIR, "Figure_6_facility_contributions.tiff")
unlink(c(fig6_pdf_file, fig6_png_file, fig6_tiff_file))

# PDF
grDevices::pdf(
  file = fig6_pdf_file,
  width = FIG6_WIDTH,
  height = FIG6_HEIGHT,
  onefile = TRUE,
  useDingbats = FALSE,
  paper = "special",
  bg = "white"
)
grid::grid.newpage()
grid::grid.draw(fig6_combined_grob)
invisible(grDevices::dev.off())
Sys.sleep(1)
fig6_pdf_saved <- file.exists(fig6_pdf_file) && file.info(fig6_pdf_file)$size > 0

# PNG
fig6_png_saved <- FALSE
if (capabilities("cairo")) {
  grDevices::png(
    filename = fig6_png_file,
    width = FIG6_WIDTH,
    height = FIG6_HEIGHT,
    units = "in",
    res = FIG6_DPI,
    type = "cairo",
    bg = "white"
  )
  grid::grid.newpage()
  grid::grid.draw(fig6_combined_grob)
  invisible(grDevices::dev.off())
  Sys.sleep(1)
  fig6_png_saved <- file.exists(fig6_png_file) && file.info(fig6_png_file)$size > 0
}

if (!fig6_png_saved && fig6_pdf_saved && nzchar(Sys.which("pdftoppm"))) {
  png_prefix <- file.path(FIG6_OUT_DIR, "Figure_6_facility_contributions")
  status <- system2(
    Sys.which("pdftoppm"),
    args = c(
      "-png", "-r", as.character(FIG6_DPI), "-singlefile",
      shQuote(fig6_pdf_file), shQuote(png_prefix)
    )
  )
  Sys.sleep(1)
  fig6_png_saved <- status == 0 &&
    file.exists(fig6_png_file) && file.info(fig6_png_file)$size > 0
}

# TIFF
fig6_tiff_saved <- FALSE
if (capabilities("cairo")) {
  grDevices::tiff(
    filename = fig6_tiff_file,
    width = FIG6_WIDTH,
    height = FIG6_HEIGHT,
    units = "in",
    res = FIG6_DPI,
    compression = "lzw",
    type = "cairo",
    bg = "white"
  )
  grid::grid.newpage()
  grid::grid.draw(fig6_combined_grob)
  invisible(grDevices::dev.off())
  Sys.sleep(1)
  fig6_tiff_saved <- file.exists(fig6_tiff_file) &&
    file.info(fig6_tiff_file)$size > 0
}

if (fig6_pdf_saved) message("PDF saved: ", normalizePath(fig6_pdf_file))
if (fig6_png_saved) message("PNG saved: ", normalizePath(fig6_png_file))
if (fig6_tiff_saved) message("TIFF saved: ", normalizePath(fig6_tiff_file))
if (!fig6_pdf_saved) warning("Figure 6 PDF was not generated.")
if (!fig6_png_saved) warning("Figure 6 PNG was not generated.")
if (!fig6_tiff_saved) warning("Figure 6 TIFF was not generated.")

message("Figure 6 outputs are located in: ", FIG6_OUT_DIR)
