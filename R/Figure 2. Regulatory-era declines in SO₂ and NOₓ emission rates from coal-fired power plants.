    tag_levels = "a",
    tag_prefix = "(",
    tag_suffix = ")",
    theme = theme(
      plot.tag = element_text(
        family = "sans",
        face = "bold",
        size = 11,
        color = "black"
      ),
      
      plot.tag.position = c(
        0.002,
        0.998
      ),
      
      plot.margin = margin(
        5,
        5,
        5,
        5
      )
    )
  )

print(figure2_combined)

