  compression = "lzw",
  bg = "white"
)

# PDF: vector format
ggsave(
  filename = file.path(
    output_dir,
    "Figure_1_historical_emissions_comparison.pdf"
  ),
  plot = figure1_combined,
  width = 7.4,
  height = 8.6,
  units = "in",
  device = "pdf",
  bg = "white"
)

message(
  "Figure 1 saved to: ",
  normalizePath(output_dir)
)
