clean_names_simple <- function(x) {
  
  x %>%
    stringr::str_trim() %>%
    stringr::str_to_lower() %>%
    stringr::str_replace_all(
      "[^a-z0-9]+",
      "_"
    ) %>%
    stringr::str_replace_all(
      "^_+|_+$",
      ""
    )
}


safe_numeric <- function(x) {
  
  suppressWarnings(
    as.numeric(
      stringr::str_replace_all(
        as.character(x),
        ",",
        ""
      )
    )
  )
}


safe_first <- function(x) {
  
  x_nonmissing <- x[
    !is.na(x) &
      as.character(x) != ""
  ]
  
  if (length(x_nonmissing) == 0) {
    return(NA)
  }
  
  x_nonmissing[1]
}


safe_ratio <- function(numerator, denominator) {
  
  if (
    !is.finite(numerator) ||
    !is.finite(denominator) ||
    denominator == 0
  ) {
    return(NA_real_)
  }
  
  numerator / denominator
}


weighted_median_safe <- function(x, w) {
  
  valid <- (
    is.finite(x) &
      is.finite(w) &
      w > 0
  )
  
  x <- x[valid]
  w <- w[valid]
  
  if (length(x) == 0) {
    return(NA_real_)
  }
  
  ord <- order(x)
  
  x <- x[ord]
  w <- w[ord]
  
  cumulative_weight <- cumsum(w) / sum(w)
  
  x[
    which(cumulative_weight >= 0.5)[1]
  ]
}


