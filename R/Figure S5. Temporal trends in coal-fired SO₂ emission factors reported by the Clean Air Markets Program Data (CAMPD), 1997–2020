# 12. DEFINE FUEL GROUP AND CALCULATE EMISSION FACTORS
# ======================================================================

campd <- campd %>%
  mutate(
    
    fuel_text = str_to_lower(
      ifelse(
        is.na(primary_fuel_types),
        "",
        primary_fuel_types
      )
    ),
    
    fuel_group = case_when(
      
      str_detect(
        fuel_text,
        "coal"
      ) ~
        "Coal",
      
      str_detect(
        fuel_text,
        "natural gas|pipeline gas|gas"
      ) ~
        "Natural gas",
      
      str_detect(
        fuel_text,
        "oil|petroleum|diesel|distillate|residual"
      ) ~
        "Oil",
      
      TRUE ~
        "Other"
    ),
    
    so2_grams =
      so2_mass_short_tons *
      907184.74,
    
    nox_grams =
      nox_mass_short_tons *
      907184.74,
    
    so2_lb =
      so2_mass_short_tons *
      2000,
    
    nox_lb =
      nox_mass_short_tons *
      2000,
    
    generation_kwh =
      gross_load_mwh *
      1000,
    
    so2_g_kwh = ifelse(
      is.finite(
        generation_kwh
      ) &
        generation_kwh > 0,
      so2_grams /
        generation_kwh,
      NA_real_
    ),
    
    nox_g_kwh = ifelse(
      is.finite(
        generation_kwh
      ) &
        generation_kwh > 0,
      nox_grams /
        generation_kwh,
      NA_real_
    ),
    
    so2_lb_mwh = ifelse(
      is.finite(
        gross_load_mwh
      ) &
        gross_load_mwh > 0,
      so2_lb /
        gross_load_mwh,
      NA_real_
    ),
    
    nox_lb_mwh = ifelse(
      is.finite(
        gross_load_mwh
      ) &
        gross_load_mwh > 0,
      nox_lb /
        gross_load_mwh,
      NA_real_
    ),
    
    so2_lb_mmbtu = ifelse(
      is.finite(
        heat_input_mmbtu
      ) &
        heat_input_mmbtu > 0,
      so2_lb /
        heat_input_mmbtu,
      NA_real_
    ),
    
    nox_lb_mmbtu = ifelse(
      is.finite(
        heat_input_mmbtu
      ) &
        heat_input_mmbtu > 0,
      nox_lb /
        heat_input_mmbtu,
      NA_real_
    )
  )


