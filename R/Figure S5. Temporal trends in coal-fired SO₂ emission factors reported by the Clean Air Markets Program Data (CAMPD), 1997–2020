annual_ef <- annual_ef %>%
  mutate(
    year = as.numeric(year),
    aggregate_so2_g_kwh = as.numeric(
      aggregate_so2_g_kwh
    ),
    aggregate_so2_lb_mmbtu = as.numeric(
      aggregate_so2_lb_mmbtu
    )
  ) %>%
  filter(
    is.finite(year),
    year >= 1997,
    year <= 2020
  )


control_annual <- control_annual %>%
  mutate(
    year = as.numeric(year),
    aggregate_so2_g_kwh = as.numeric(
      aggregate_so2_g_kwh
    ),
    
    binary_control_group = case_when(
      
      binary_control_group ==
        "At least one unit reported control" ~
        "At least one unit reported control",
      
      binary_control_group ==
        "No unit reported control" ~
        "No unit reported control",
      
      TRUE ~
        binary_control_group
    ),
    
    binary_control_group = factor(
      binary_control_group,
      levels = c(
        "No unit reported control",
        "At least one unit reported control"
      )
    )
  ) %>%
  filter(
    is.finite(year),
    year >= 1997,
    year <= 2020,
    !is.na(binary_control_group)
  )


