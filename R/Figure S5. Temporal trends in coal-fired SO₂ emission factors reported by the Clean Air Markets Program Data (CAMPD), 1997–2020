    n_total_units = n_distinct(
      unit_id
    ),
    
    n_coal_units = n_distinct(
      unit_id[
        unit_is_coal
      ]
    ),
    
    n_units_with_reported_so2_control = n_distinct(
      unit_id[
        unit_has_reported_so2_control
      ]
    ),
    
    n_units_without_reported_so2_control = n_distinct(
      unit_id[
        !unit_has_reported_so2_control
      ]
    ),
    
    any_reported_so2_control = any(
      unit_has_reported_so2_control,
      na.rm = TRUE
    ),
    
    all_units_reported_so2_control = all(
      unit_has_reported_so2_control
    ),
    
    share_units_with_reported_so2_control =
      n_units_with_reported_so2_control /
      n_total_units,
    
    primary_fuel_types = paste(
      sort(
        unique(
          as.character(
            primary_fuel_type[
              !is.na(primary_fuel_type) &
                as.character(primary_fuel_type) != ""
            ]
          )
        )
      ),
      collapse = "; "
    ),
    
    reported_so2_control_types = paste(
      sort(
        unique(
          as.character(
            so2_controls[
              !is.na(so2_controls) &
                str_trim(
                  as.character(
                    so2_controls
                  )
                ) != ""
            ]
          )
        )
