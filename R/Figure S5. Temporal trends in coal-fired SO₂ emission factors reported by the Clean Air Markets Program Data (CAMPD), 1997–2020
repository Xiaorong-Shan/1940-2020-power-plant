      collapse = "; "
    ),
    
    .groups = "drop"
  ) %>%
  mutate(
    
    facility_control_group = case_when(
      
      n_units_with_reported_so2_control == 0 ~
        "No reported control",
      
      n_units_with_reported_so2_control ==
        n_total_units ~
        "All units reported control",
      
      n_units_with_reported_so2_control > 0 &
        n_units_with_reported_so2_control <
        n_total_units ~
        "Mixed control status",
      
      TRUE ~
        "Unknown"
    ),
    
    binary_control_group = ifelse(
      any_reported_so2_control,
      "At least one unit reported control",
      "No unit reported control"
    )
  )


