to_numeric_clean <- function(x) {
  x <- trimws(as.character(x))
  x[x %in% c("", "NA", "N/A", "na", "n/a", "--", ".")] <- NA_character_
  x <- gsub(",", "", x, fixed = TRUE)
  suppressWarnings(as.numeric(x))
}

first_matching_column <- function(column_names, patterns, required = TRUE) {
  for (pattern in patterns) {
    hit <- column_names[str_detect(column_names, regex(pattern, ignore_case = TRUE))]
    if (length(hit) > 0) return(hit[1])
  }
  if (required) {
    stop("No column matched: ", paste(patterns, collapse = " | "))
  }
  NA_character_
}

map_fuel_group <- function(x) {
  lower <- tolower(as.character(x))
  case_when(
    str_detect(lower, "coal|bituminous|subbituminous|lignite") ~ "Coal",
    str_detect(lower, "natural gas|gas|gaseous") ~ "Gas",
    str_detect(lower, "oil|petroleum|diesel|distillate|residual") ~ "Oil",
    str_detect(lower, "biomass|wood|waste|landfill") ~ "Biomass",
    TRUE ~ "Other"
  )
}

