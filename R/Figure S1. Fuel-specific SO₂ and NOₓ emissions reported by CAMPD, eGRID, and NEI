}

egrid_sheet_rule <- function(path, year) {
  sheets <- excel_sheets(path)

  if (year %in% c(1998, 1999, 2000)) {
    desired <- sprintf("EGRDPLNT%02d", year %% 100)
    skip <- 3
  } else if (year == 2004) {
    desired <- "EGRDPLNT04"
    skip <- 5
  } else if (year %in% c(2005, 2007, 2009, 2010, 2012)) {
    desired <- sprintf("PLNT%02d", year %% 100)
    skip <- 4
  } else {
    candidates <- sheets[str_detect(toupper(sheets), "PLNT|PLANT")]
    desired <- if (length(candidates) > 0) candidates[1] else sheets[1]
    skip <- 1
  }

  if (!(desired %in% sheets)) {
    candidates <- sheets[str_detect(toupper(sheets), "PLNT|PLANT")]
    desired <- if (length(candidates) > 0) candidates[1] else sheets[1]
  }

  list(sheet = desired, skip = skip)
}

read_egrid_file <- function(base_name) {
  path <- find_egrid_file(base_name)
  if (is.na(path)) {
    warning("Missing eGRID file: ", base_name)
    return(tibble())
  }

  year <- as.integer(str_extract(base_name, "\\d{4}"))
  rule <- egrid_sheet_rule(path, year)
  skip_candidates <- unique(c(rule$skip, pmax(0, rule$skip - 1), rule$skip + 1, 0:7))

  accepted <- NULL
  used_skip <- NA_integer_

  for (skip_value in skip_candidates) {
    attempt <- tryCatch(
      read_excel(
        path,
        sheet = rule$sheet,
        skip = skip_value,
        col_types = "text",
        guess_max = 100000
      ) %>%
        clean_names(),
      error = function(e) NULL
    )

    if (is.null(attempt)) next
    attempt_names <- names(attempt)

    has_fuel <- any(str_detect(attempt_names, "^plprimfl|^plprmfl|^fuelb1|primary.*fuel"))
    has_so2 <- any(str_detect(attempt_names, "^plso2an|so2.*annual"))
    has_nox <- any(str_detect(attempt_names, "^plnoxan|nox.*annual"))
    has_co2 <- any(str_detect(attempt_names, "^plco2an|co2.*annual"))

    if (has_fuel && has_so2 && has_nox && has_co2) {
      accepted <- attempt
      used_skip <- skip_value
      break
    }
  }

  if (is.null(accepted)) {
    warning("Could not identify eGRID columns for year ", year, ": ", basename(path))
    return(tibble())
  }

  nms <- names(accepted)
  fuel_col <- first_matching_column(
    nms, c("^plprimfl", "^plprmfl", "^fuelb1", "primary.*fuel")
  )
  so2_col <- first_matching_column(nms, c("^plso2an", "so2.*annual"))
  nox_col <- first_matching_column(nms, c("^plnoxan", "nox.*annual"))
  co2_col <- first_matching_column(nms, c("^plco2an", "co2.*annual"))
  hg_col <- first_matching_column(nms, c("^plhgan", "hg.*annual"), required = FALSE)

  message(
    "eGRID ", year,
    ": ", basename(path),
    " | sheet=", rule$sheet,
    " | skip=", used_skip
  )

  accepted %>%
    transmute(
      # Use the integer parsed from the filename. Some eGRID workbooks
      # contain their own character-valued `year` column, which would
      # otherwise take precedence inside dplyr's data mask.
      year = .env$year,
      primary_fuel = .data[[fuel_col]],
      so2_short_tons = to_numeric_clean(.data[[so2_col]]),
      nox_short_tons = to_numeric_clean(.data[[nox_col]]),
      co2_short_tons = to_numeric_clean(.data[[co2_col]]),
      hg_lbs = if (!is.na(hg_col)) to_numeric_clean(.data[[hg_col]]) else NA_real_
    )
}

