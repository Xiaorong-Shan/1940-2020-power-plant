#!/usr/bin/env Rscript

# ================================================================
# Figure 4: monitor-level comparison of modeled coal PM2.5
# against observed sulfate in 1980 and 1990
# ================================================================

# Prevent objects from earlier figures from being reused.
rm(list = ls(all.names = TRUE))
graphics.off()

suppressPackageStartupMessages({
  library(data.table)
  library(fst)
  library(sf)
  library(ggplot2)
  library(grid)
  library(gridExtra)
})

# ------------------------------
# 0. Settings
# ------------------------------

FIG4_CRS <- paste0(
  "+proj=aea +lat_1=20 +lat_2=60 ",
  "+lat_0=40 +lon_0=-96 +x_0=0 +y_0=0 ",
  "+ellps=GRS80 +datum=NAD83 +units=m"
)

FIG4_BASE_DIR <- paste0(
  "/scratch/xshan2/R_Code/disperseR/main/output/",
  "pm25_decades_model.lm.cv_single_poly_proxy1999met"
)

FIG4_EVAL_DIR <- file.path(FIG4_BASE_DIR, "evaluation")
FIG4_OUT_DIR <- file.path(FIG4_EVAL_DIR, "aqs_hyads_eval_figure4")
dir.create(FIG4_OUT_DIR, recursive = TRUE, showWarnings = FALSE)

FIG4_MAX_DISTANCE_M <- 100000
FIG4_WIDTH <- 7.4
FIG4_HEIGHT <- 3.8
FIG4_DPI <- 600

fig4_aqs_files <- list(
  `1980` = file.path(FIG4_EVAL_DIR, "annual_conc_by_monitor_1980.csv"),
  `1990` = file.path(FIG4_EVAL_DIR, "annual_conc_by_monitor_1990.csv")
)

fig4_hyads_files <- list(
  `1980` = file.path(FIG4_BASE_DIR, "grids_pm25_total_1980.fst"),
  `1990` = file.path(FIG4_BASE_DIR, "grids_pm25_total_1990.fst")
)

missing_aqs <- unlist(fig4_aqs_files)[!file.exists(unlist(fig4_aqs_files))]
missing_hyads <- unlist(fig4_hyads_files)[!file.exists(unlist(fig4_hyads_files))]

if (length(missing_aqs) > 0) {
  stop("Missing AQS files:\n", paste(missing_aqs, collapse = "\n"))
}

if (length(missing_hyads) > 0) {
  stop("Missing HyADS files:\n", paste(missing_hyads, collapse = "\n"))
}

message("Figure 4 output directory: ", FIG4_OUT_DIR)

# ------------------------------
# 1. Helper functions
# ------------------------------

fig4_read_aqs <- function(file_path) {
  dt <- fread(file_path)
  setnames(dt, gsub(" ", "_", names(dt)))

  required <- c(
    "State_Code", "County_Code", "Site_Num", "Latitude", "Longitude",
    "Parameter_Name", "Parameter_Code", "Arithmetic_Mean", "Year"
  )
  missing <- setdiff(required, names(dt))
  if (length(missing) > 0) {
    stop("AQS file is missing columns: ", paste(missing, collapse = ", "))
  }

  dt[, State_Code := as.integer(State_Code)]
  dt[, County_Code := as.integer(County_Code)]
  dt[, Site_Num := as.integer(Site_Num)]
  dt[, Latitude := as.numeric(Latitude)]
  dt[, Longitude := as.numeric(Longitude)]
  dt[, Arithmetic_Mean := as.numeric(Arithmetic_Mean)]
  dt[, Year := as.integer(Year)]
  dt
}

fig4_read_hyads <- function(file_path) {
  dt <- fst::read_fst(file_path, as.data.table = TRUE)
  required <- c("x", "y", "vals.out")
  missing <- setdiff(required, names(dt))
  if (length(missing) > 0) {
    stop("HyADS file is missing columns: ", paste(missing, collapse = ", "))
  }

  dt[, x := as.numeric(x)]
  dt[, y := as.numeric(y)]
  dt[, vals.out := as.numeric(vals.out)]
  dt <- dt[is.finite(x) & is.finite(y) & is.finite(vals.out)]

  st_as_sf(
    dt,
    coords = c("x", "y"),
    crs = st_crs(FIG4_CRS),
    remove = FALSE
  )
}

fig4_site_id <- function(state_code, county_code, site_number) {
  paste0(
    sprintf("%02d", as.integer(state_code)), "_",
    sprintf("%03d", as.integer(county_code)), "_",
    sprintf("%04d", as.integer(site_number))
  )
}

fig4_aggregate_monitors <- function(aqs_data) {
  if (nrow(aqs_data) == 0) stop("No sulfate observations were found.")

  dt <- copy(aqs_data)
  dt[, site_id := fig4_site_id(State_Code, County_Code, Site_Num)]
  dt <- dt[
    is.finite(Longitude) & is.finite(Latitude) & is.finite(Arithmetic_Mean)
  ]

  site_data <- dt[, .(
    longitude = mean(Longitude, na.rm = TRUE),
    latitude = mean(Latitude, na.rm = TRUE),
    observed = mean(Arithmetic_Mean, na.rm = TRUE),
    year = Year[1],
    parameter_name = Parameter_Name[1],
    parameter_code = Parameter_Code[1],
    n_aqs_records = .N
  ), by = site_id]

  site_data <- site_data[
    is.finite(longitude) & is.finite(latitude) & is.finite(observed)
  ]

  st_as_sf(
    site_data,
    coords = c("longitude", "latitude"),
    crs = 4326,
    remove = FALSE
  )
}

fig4_match_hyads <- function(monitor_sf, hyads_sf) {
  monitor_projected <- st_transform(monitor_sf, st_crs(FIG4_CRS))
  nearest_index <- st_nearest_feature(monitor_projected, hyads_sf)

  monitor_projected$modeled <- hyads_sf$vals.out[nearest_index]
  monitor_projected$hyads_x <- hyads_sf$x[nearest_index]
  monitor_projected$hyads_y <- hyads_sf$y[nearest_index]
  monitor_projected$match_distance_m <- as.numeric(
    st_distance(
      monitor_projected,
      hyads_sf[nearest_index, ],
      by_element = TRUE
    )
  )
  monitor_projected
}

fig4_metrics <- function(observed, modeled) {
  valid <- is.finite(observed) & is.finite(modeled)
  observed <- observed[valid]
  modeled <- modeled[valid]
  n <- length(observed)
  if (n < 3) stop("Fewer than three valid matched monitors.")

  difference <- modeled - observed
  pearson_r <- suppressWarnings(cor(observed, modeled, method = "pearson"))
  spearman_rho <- suppressWarnings(cor(observed, modeled, method = "spearman"))

  list(
    n = n,
    mean_observed = mean(observed, na.rm = TRUE),
    mean_modeled = mean(modeled, na.rm = TRUE),
    mean_bias = mean(difference, na.rm = TRUE),
    mae = mean(abs(difference), na.rm = TRUE),
    rmse = sqrt(mean(difference^2, na.rm = TRUE)),
    pearson_r = pearson_r,
    spearman_rho = spearman_rho,
    r2 = pearson_r^2
  )
}

# ------------------------------
# 2. Load data
# ------------------------------

message("Loading AQS data.")
fig4_aqs <- lapply(fig4_aqs_files, fig4_read_aqs)

message("Loading HyADS grids.")
fig4_hyads <- lapply(fig4_hyads_files, fig4_read_hyads)

# ------------------------------
# 3. Match AQS sulfate monitors to HyADS grids
# ------------------------------

fig4_matched_data <- list()
fig4_statistics <- list()

for (year_value in c(1980, 1990)) {
  year_character <- as.character(year_value)
  message("Processing ", year_value)

  aqs_year <- fig4_aqs[[year_character]]
  hyads_year <- fig4_hyads[[year_character]]

  sulfate_data <- aqs_year[
    grepl("^Sulfate \\(TSP\\)", Parameter_Name)
  ]
  message("Raw sulfate rows: ", nrow(sulfate_data))
  if (nrow(sulfate_data) == 0) {
    stop("No sulfate (TSP) observations found for ", year_value)
  }

  monitor_sf <- fig4_aggregate_monitors(sulfate_data)
  matched_sf <- fig4_match_hyads(monitor_sf, hyads_year)
  matched_dt <- as.data.table(st_drop_geometry(matched_sf))
  matched_dt <- matched_dt[
    is.finite(observed) & is.finite(modeled) & is.finite(match_distance_m)
  ]

  message("Before distance filter: ", nrow(matched_dt))
  matched_dt <- matched_dt[match_distance_m <= FIG4_MAX_DISTANCE_M]
  message("After distance filter: ", nrow(matched_dt))
  if (nrow(matched_dt) < 3) stop("Too few matched monitors for ", year_value)

  matched_dt[, year := year_value]
  fig4_matched_data[[year_character]] <- matched_dt

  metrics <- fig4_metrics(matched_dt$observed, matched_dt$modeled)
  fig4_statistics[[year_character]] <- data.table(
    year = year_value,
    n = metrics$n,
    mean_observed = metrics$mean_observed,
    mean_modeled = metrics$mean_modeled,
    mean_bias = metrics$mean_bias,
    mae = metrics$mae,
    rmse = metrics$rmse,
    pearson_r = metrics$pearson_r,
    spearman_rho = metrics$spearman_rho,
    r2 = metrics$r2,
    median_match_distance_km = median(matched_dt$match_distance_m) / 1000,
    maximum_match_distance_km = max(matched_dt$match_distance_m) / 1000
  )

  fwrite(
    matched_dt,
    file.path(
      FIG4_OUT_DIR,
      paste0("Figure4_matched_monitor_data_", year_value, ".csv")
    )
  )
}

if (!all(c("1980", "1990") %in% names(fig4_matched_data))) {
  stop("Matched data were not created for both 1980 and 1990.")
}

message("1980 matched monitors: ", nrow(fig4_matched_data[["1980"]]))
message("1990 matched monitors: ", nrow(fig4_matched_data[["1990"]]))

fig4_stats <- rbindlist(fig4_statistics)
setorder(fig4_stats, year)
fwrite(
  fig4_stats,
  file.path(FIG4_OUT_DIR, "Figure4_validation_statistics.csv")
)
print(fig4_stats)

# ------------------------------
# 4. Plot function
# ------------------------------

fig4_make_plot <- function(plot_data, year_label, panel_label) {
  metrics <- fig4_metrics(plot_data$observed, plot_data$modeled)
  annotation_text <- sprintf(
    "n = %d\nPearson r = %.2f\nSpearman r = %.2f\nR² = %.2f",
    metrics$n,
    metrics$pearson_r,
    metrics$spearman_rho,
    metrics$r2
  )

  ggplot(plot_data, aes(x = observed, y = modeled)) +
    geom_point(color = "black", alpha = 0.45, size = 1.3) +
    geom_smooth(
      method = "lm",
      formula = y ~ x,
      se = FALSE,
      color = "#3568D4",
      linewidth = 0.9
    ) +
    annotate(
      "text",
      x = Inf,
      y = Inf,
      label = annotation_text,
      hjust = 1.05,
      vjust = 1.12,
      size = 3.2,
      lineheight = 0.95
    ) +
    scale_x_continuous(expand = expansion(mult = c(0.02, 0.04))) +
    scale_y_continuous(expand = expansion(mult = c(0.03, 0.06))) +
    labs(
      tag = panel_label,
      title = year_label,
      x = expression("Observed sulfate (" * mu * "g " * m^{-3} * ")"),
      y = expression(
        "Modeled coal PM"[2.5] * " (" * mu * "g " * m^{-3} * ")"
      )
    ) +
    theme_bw(base_size = 10, base_family = "sans") +
    theme(
      text = element_text(color = "black"),
      plot.title = element_text(
        size = 11,
        face = "bold",
        hjust = 0.5,
        margin = margin(b = 4)
      ),
      plot.tag = element_text(size = 11, face = "bold"),
      plot.tag.position = c(0.015, 0.985),
      axis.title = element_text(size = 9.5),
      axis.text = element_text(size = 8.5, color = "black"),
      axis.ticks = element_line(color = "black", linewidth = 0.35),
      panel.grid.major = element_line(color = "grey88", linewidth = 0.3),
      panel.grid.minor = element_blank(),
      panel.border = element_rect(color = "grey35", fill = NA, linewidth = 0.45),
      plot.margin = margin(8, 8, 6, 8)
    )
}

# ------------------------------
# 5. Create and combine Figure 4 panels
# ------------------------------

fig4_panel_a <- fig4_make_plot(
  fig4_matched_data[["1980"]],
  year_label = "1980",
  panel_label = "(a)"
)

fig4_panel_b <- fig4_make_plot(
  fig4_matched_data[["1990"]],
  year_label = "1990",
  panel_label = "(b)"
)

fig4_combined_grob <- gridExtra::arrangeGrob(
  fig4_panel_a,
  grid::nullGrob(),
  fig4_panel_b,
  ncol = 3,
  widths = c(1, 0.05, 1)
)

grid::grid.newpage()
grid::grid.draw(fig4_combined_grob)

# ------------------------------
# 6. Save PDF, PNG, and TIFF
# ------------------------------

fig4_pdf_file <- file.path(FIG4_OUT_DIR, "Figure_4_AQS_sulfate_validation.pdf")
fig4_png_file <- file.path(FIG4_OUT_DIR, "Figure_4_AQS_sulfate_validation.png")
fig4_tiff_file <- file.path(FIG4_OUT_DIR, "Figure_4_AQS_sulfate_validation.tiff")

unlink(c(fig4_pdf_file, fig4_png_file, fig4_tiff_file))

# PDF
grDevices::pdf(
  file = fig4_pdf_file,
  width = FIG4_WIDTH,
  height = FIG4_HEIGHT,
  onefile = TRUE,
  useDingbats = FALSE,
  paper = "special",
  bg = "white"
)
grid::grid.newpage()
grid::grid.draw(fig4_combined_grob)
invisible(grDevices::dev.off())
Sys.sleep(1)
fig4_pdf_saved <- file.exists(fig4_pdf_file) && file.info(fig4_pdf_file)$size > 0

# PNG: direct Cairo rendering, then PDF conversion fallback.
fig4_png_saved <- FALSE
if (capabilities("cairo")) {
  grDevices::png(
    filename = fig4_png_file,
    width = FIG4_WIDTH,
    height = FIG4_HEIGHT,
    units = "in",
    res = FIG4_DPI,
    type = "cairo",
    bg = "white"
  )
  grid::grid.newpage()
  grid::grid.draw(fig4_combined_grob)
  invisible(grDevices::dev.off())
  Sys.sleep(1)
  fig4_png_saved <- file.exists(fig4_png_file) && file.info(fig4_png_file)$size > 0
}

if (!fig4_png_saved && fig4_pdf_saved && nzchar(Sys.which("pdftoppm"))) {
  png_prefix <- file.path(FIG4_OUT_DIR, "Figure_4_AQS_sulfate_validation")
  status <- system2(
    Sys.which("pdftoppm"),
    args = c(
      "-png", "-r", as.character(FIG4_DPI), "-singlefile",
      shQuote(fig4_pdf_file), shQuote(png_prefix)
    )
  )
  Sys.sleep(1)
  fig4_png_saved <- status == 0 &&
    file.exists(fig4_png_file) && file.info(fig4_png_file)$size > 0
}

# TIFF
fig4_tiff_saved <- FALSE
if (capabilities("cairo")) {
  grDevices::tiff(
    filename = fig4_tiff_file,
    width = FIG4_WIDTH,
    height = FIG4_HEIGHT,
    units = "in",
    res = FIG4_DPI,
    compression = "lzw",
    type = "cairo",
    bg = "white"
  )
  grid::grid.newpage()
  grid::grid.draw(fig4_combined_grob)
  invisible(grDevices::dev.off())
  Sys.sleep(1)
  fig4_tiff_saved <- file.exists(fig4_tiff_file) &&
    file.info(fig4_tiff_file)$size > 0
}

if (fig4_pdf_saved) message("PDF saved: ", normalizePath(fig4_pdf_file))
if (fig4_png_saved) message("PNG saved: ", normalizePath(fig4_png_file))
if (fig4_tiff_saved) message("TIFF saved: ", normalizePath(fig4_tiff_file))
if (!fig4_pdf_saved) warning("Figure 4 PDF was not generated.")
if (!fig4_png_saved) warning("Figure 4 PNG was not generated.")
if (!fig4_tiff_saved) warning("Figure 4 TIFF was not generated.")

message("Figure 4 outputs are located in: ", FIG4_OUT_DIR)
